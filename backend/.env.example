PORT=5000
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/legatee?retryWrites=true&w=majority

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

CORS_ORIGIN=http://localhost:3000

# Admin JWT secret (separate from user JWT)
JWT_ADMIN_SECRET=generate-a-long-random-secret-here

# User JWT secret (separate from admin JWT)
JWT_USER_SECRET=generate-a-different-long-random-secret-here

# Legacy fallback (used if JWT_ADMIN_SECRET / JWT_USER_SECRET are not set)
JWT_SECRET=generate-a-fallback-long-random-secret-here

DASHBOARD_EMAIL=admin@yourdomain.com
# Use bcrypt hash: node -e "require('bcryptjs').hash('YourPass',12).then(console.log)"
DASHBOARD_PASSWORD=$2b$12$...your_bcrypt_hash_here

BACKEND_URL=http://localhost:5000

BUSINESS_EMAIL=your@gmail.com
EMAIL_PASS=your_gmail_app_password

TABBY_SECRET_KEY=sk_test_YOUR_TABBY_SECRET_KEY
TABBY_PUBLIC_KEY=pk_test_YOUR_TABBY_PUBLIC_KEY
TABBY_MERCHANT_CODE=YOUR_TABBY_MERCHANT_CODE
TABBY_WEBHOOK_SECRET=YOUR_TABBY_WEBHOOK_SECRET

TAMARA_API_TOKEN=YOUR_TAMARA_API_TOKEN
TAMARA_NOTIFICATION_TOKEN=YOUR_TAMARA_NOTIFICATION_TOKEN
TAMARA_PUBLIC_KEY=YOUR_TAMARA_PUBLIC_KEY
TAMARA_BASE_URL=https://api-sandbox.tamara.co

DHL_API_KEY=YOUR_DHL_API_KEY
DHL_API_SECRET=YOUR_DHL_API_SECRET
DHL_ACCOUNT_NUMBER=YOUR_DHL_ACCOUNT_NUMBER
DHL_BASE_URL=https://express.api.dhl.com/mydhlapi/test
